<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDisplayName</key>
	<string>ClipDrop</string>
	<key>CFBundleIdentifier</key>
	<string>com.Amaury.Aidrop-Clipboard</string>
	<key>CFBundleName</key>
	<string>Aidrop-Clipboard</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>LSUIElement</key>
	<true/>
	<key>LSApplicationCategoryType</key>
	<string>public.app-category.utilities</string>
	<key>NSDownloadsFolderUsageDescription</key>
	<string>This permission is necessary to automatically detect and copy texts received via AirDrop.</string>
	<key>NSAppleEventsUsageDescription</key>
	<string>Hide the Finder window</string>
	
	<key>CFBundleDocumentTypes</key>
	<array>
		<dict>
			<key>CFBundleTypeName</key>
			<string>Plain Text</string>
			<key>CFBundleTypeRole</key>
			<string>Viewer</string>
			<key>LSItemContentTypes</key>
			<array>
				<string>public.plain-text</string>
				<string>public.text</string>
			</array>
			<key>LSHandlerRank</key>
			<string>Default</string>
		</dict>
		<dict>
			<key>CFBundleTypeName</key>
			<string>Clipboard File</string>
			<key>CFBundleTypeExtensions</key>
			<array>
				<string>aidropclip</string>
				<string>clipboard</string>
			</array>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>LSHandlerRank</key>
			<string>Owner</string>
		</dict>
	</array>
</dict>
</plist>
